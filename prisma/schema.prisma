generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  telegramId   String?       @unique
  name         String
  role         String        @default("USER") // ADMIN or USER
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

model Item {
  id           String        @id @default(cuid())
  name         String        @unique
  quantity     Int           @default(0)   // zaxira HAR DOIM bazaviy birlikda (dona)
  price        Float         @default(0)   // narx HAR DOIM 1 dona uchun
  unit         String        @default("Dona") // bazaviy (dona) birlik nomi
  packSize     Int           @default(1)   // 1 pachkada nechta dona (1 = pachka yo'q)
  packUnit     String        @default("pachka") // pachka birligi nomi
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Transaction {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  itemId     String
  item       Item     @relation(fields: [itemId], references: [id])
  quantity   Int      // Pozitiv - qo'shish, negativ - olish
  type       String   // 'TAKE', 'RETURN', 'ADD', 'ADJUST'
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  image      String?  // Rasm file_id
  eventName  String?  // Qaysi tadbir uchun olingani
  totalPrice Float?   // quantity * item.price
  unitMode   String?  // "pack" | "piece" — chiqim qaysi birlikda kiritilgani
  createdAt  DateTime @default(now())
}
